# Copy to .env and fill in values. NEVER commit .env.
# In CI: set Secrets for keys, Variables for non-secret config.

# ── Claude Code CLI ───────────────────────────────────────────────────────────
# Required for headless runs (claude --print).
# CI: set as a repository Secret (Settings → Secrets → Actions)
ANTHROPIC_API_KEY=

# ── Kill Switch ───────────────────────────────────────────────────────────────
# Max API spend per session in USD. Enforced by .claude/hooks/pre-tool-use.py.
# CI: set as a repository Variable (Settings → Variables → Actions)
BUDGET_USD=5.00

# Max tool invocations per session (proxy kill switch, works without cost data).
# Enforced by .claude/hooks/pre-tool-use.py + post-tool-use.py.
# CI: set as a repository Variable or pass as workflow_dispatch input
CLAUDE_MAX_TURNS=50

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── External Consult APIs ─────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Project-specific secrets (add below) ──────────────────────────────────────
